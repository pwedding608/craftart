# Supabase (Project Settings > API)
VITE_SUPABASE_URL=
# Use your publishable public key, or the legacy "anon" JWT:
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=

# Public site (no trailing slash for canonical / OG).
# Local dev: http://localhost:5173 | Production (set in Vercel env too): https://craftart-topaz.vercel.app
VITE_SITE_URL=http://localhost:5173

# Brand & contact
VITE_WHATSAPP_NUMBER=91XXXXXXXXXX
VITE_INSTAGRAM_URL=https://www.instagram.com/yourhandle
VITE_BRAND_EMAIL=hello@example.com
# Google Maps embed (Share > Embed a map)
VITE_MAPS_EMBED_URL=
